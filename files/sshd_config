Port 22
Protocol 2

PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys

AllowUsers eetu

MaxAuthTries 3
LoginGraceTime 30
ClientAliveInterval 300
ClientAliveCountMax 2
UseDNS no
AllowTcpForwarding no
PermitTunnel no

X11Forwarding no
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server

# Global default stays no (above). Scoped exception: allow the admin user to
# TCP-forward so local dev can tunnel to loopback-only services (gatus :3001,
# beszel :8091) for the raspi-dashboard app. eetu's key already grants shell +
# sudo, so this adds negligible marginal risk over the existing access.
# Match blocks must be last — everything after this line is conditional.
Match User eetu
    AllowTcpForwarding yes
